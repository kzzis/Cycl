{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cycl",
  "version": "0.1.0",
  "identifier": "com.cycl.app",
  "build": {
    "beforeDevCommand": "sh -c \"pkill -9 -x dx 2>/dev/null; mise exec -- dx serve --port 1420 --interactive false\"",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "mise exec -- dx bundle --release",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cycl",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0a0e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
